# Druckenmiller Alpha System - Environment Variables
# Copy this file to .env and fill in your credentials.

# ── Core Data APIs ──
# FRED (free): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Financial Modeling Prep (free tier): https://site.financialmodelingprep.com/developer
FMP_API_KEY=your_fmp_api_key_here

# Finnhub (free tier): https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpha Vantage (free tier): https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# EIA (free): https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# ── AI / LLM ──
# Google Gemini (free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Web Search & Scraping ──
# Serper (free trial): https://serper.dev/
SERPER_API_KEY=your_serper_api_key_here

# Firecrawl (free tier): https://firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# ── Translation ──
# DeepL (free tier): https://www.deepl.com/pro-api
DEEPL_API_KEY=your_deepl_api_key_here

# ── Satellite & Alt Data ──
# NASA FIRMS (free): https://firms.modaps.eosdis.nasa.gov/api/area/
NASA_FIRMS_API_KEY=your_nasa_firms_key_here

# USDA (free): https://quickstats.nass.usda.gov/api
USDA_API_KEY=your_usda_api_key_here

# ── Social ──
# Reddit API (free — register at reddit.com/prefs/apps, create a "script" app)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# ── Email Alerts (Gmail SMTP) ──
# Use a Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_TO=your_email@example.com

# ── Portfolio ──
PORTFOLIO_VALUE=100000

# ── On-Chain (optional) ──
# Nansen (enterprise): https://nansen.ai/
NANSEN_API_KEY=your_nansen_api_key_here

# Etherscan (free tier): https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ── Patent Data (optional) ──
# EPO (European Patent Office): https://developers.epo.org/
EPO_CONSUMER_KEY=your_epo_consumer_key_here
EPO_CONSUMER_SECRET=your_epo_consumer_secret_here

# ── Database ──
# PostgreSQL connection string (local or cloud e.g. Neon, Supabase)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
